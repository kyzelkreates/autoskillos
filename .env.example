# AutoSkill OS™ — Environment Variables Example
# Powered by 4P3X Intelligent AI™ — Created by Kyzel Kreates™
#
# ─────────────────────────────────────────────────────────────────────────────
# PUBLIC / CLIENT-SAFE VARIABLES ONLY
# Copy this file to .env and fill in your real public values.
#
# ⛔ NEVER place any of the following in frontend env files:
#   SUPABASE_SERVICE_ROLE_KEY
#   DATABASE_URL
#   JWT_SECRET
#   PRIVATE_KEY
#   WEBHOOK_SECRET
#   OPENAI_API_KEY
#   GROQ_API_KEY
#   STRIPE_SECRET_KEY
#   AWS_SECRET_ACCESS_KEY
#   secretAccessKey
#   service account JSON
#   admin tokens
#   private_key
#   client_secret
#
# These must only live in server-side / backend environments.
# The 4P3X API Config Guard™ will block these from being saved in the UI.
# ─────────────────────────────────────────────────────────────────────────────

# App identity
VITE_AUTOSKILL_APP_NAME=AutoSkill OS
VITE_AUTOSKILL_DATA_MODE=demo

# Supabase (public/client-safe only)
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=your_public_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_public_supabase_anon_key

# Firebase (public web config only — NOT service account)
# Get from: Firebase Console → Project Settings → Your apps → Web app config
VITE_FIREBASE_API_KEY=your_public_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com

# AWS / Custom backend (public-safe fields only)
VITE_AWS_API_BASE_URL=https://your-api-gateway-url.execute-api.region.amazonaws.com/stage
VITE_AWS_REGION=eu-west-1

# Custom REST endpoint
VITE_API_BASE_URL=https://your-api.example.com
VITE_API_HEALTH_PATH=/health

# ─────────────────────────────────────────────────────────────────────────────
# Run 7 will connect Employee PWA to Control Dashboard sync queue.
# Run 8 will add final reports, validation, and deployment readiness.
# AutoSkill OS™ remains local-first until a live backend is configured.
# ─────────────────────────────────────────────────────────────────────────────
