# ════════════════════════════════════════════════════════════════════════════
# AutoSkill OS™ — Environment Variables Template
# Powered by 4P3X Intelligent AI™ · Created by Kyzel Kreates™
# ────────────────────────────────────────────────────────────────────────────
# SAFE TO COMMIT: This file contains only public-safe placeholder values.
# Copy to .env (local) or add to Vercel / Netlify environment settings.
# ════════════════════════════════════════════════════════════════════════════

# ── App Identity ──────────────────────────────────────────────────────────────
VITE_AUTOSKILL_APP_NAME=AutoSkill OS
VITE_AUTOSKILL_DATA_MODE=demo

# ── Supabase Public Config ────────────────────────────────────────────────────
# These are PUBLIC/client-safe values — safe to use in frontend.
# Found in: Supabase Dashboard → Settings → API → Project URL / anon key
VITE_SUPABASE_URL=your_public_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_public_supabase_anon_key

# ── Optional: App version / build tags ───────────────────────────────────────
# VITE_AUTOSKILL_VERSION=1.0.0
# VITE_AUTOSKILL_BUILD_RUN=12

# ════════════════════════════════════════════════════════════════════════════
# ⛔ NEVER PLACE THESE IN THIS FILE OR ANY FRONTEND ENV FILE:
# ════════════════════════════════════════════════════════════════════════════
#
# SUPABASE_SERVICE_ROLE_KEY   ← backend-only, bypasses RLS, never in frontend
# DATABASE_URL                ← backend-only connection string
# JWT_SECRET                  ← backend-only signing secret
# PRIVATE_KEY                 ← any private key of any kind
# WEBHOOK_SECRET              ← backend-only webhook validation
# OPENAI_API_KEY              ← backend-only AI key
# GROQ_API_KEY                ← backend-only AI key
# STRIPE_SECRET_KEY           ← backend-only payment key
# AWS_SECRET_ACCESS_KEY       ← backend-only AWS credential
# client_secret               ← OAuth client secret
# admin_token                 ← any admin or service token
# service account JSON        ← Firebase/GCP service account
# private_key (any form)      ← any private or signing key
#
# The 4P3X API Config Guard™ will block these terms from being saved
# in the AutoSkill OS™ Settings panel.
# ════════════════════════════════════════════════════════════════════════════
